      "id": 1,
      "options": {
        "content": "## Node On Host View\n\nSource: official `node exporter` on the host on `9102`.\n\nThis dashboard shows only the metrics exposed by the host-side official exporter.",
        "mode": "markdown"
      },
      "title": "Overview",
      "type": "text"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 5},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"host-node-exporter\",mode=\"idle\"}[5m])) * 100)", "refId": "A"}],
      "title": "CPU Used",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 5},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name"},
      "targets": [{"expr": "node_memory_MemTotal_bytes{job=\"host-node-exporter\"}", "refId": "A"}],
      "title": "Total Memory",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 5},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name"},
      "targets": [{"expr": "node_memory_MemTotal_bytes{job=\"host-node-exporter\"} - node_memory_MemAvailable_bytes{job=\"host-node-exporter\"}", "refId": "A"}],
      "title": "Current Memory Used",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 5},
      "id": 5,
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name"},
      "targets": [{"expr": "up{job=\"host-node-exporter\"}", "refId": "A"}],
      "title": "Exporter Status",
      "type": "stat"
    }
