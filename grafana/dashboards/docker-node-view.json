  "editable": true,
  "id": null,
  "panels": [
    {
      "gridPos": {"h": 5, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "content": "## Node In Docker View\n\nSource: official `node exporter` in Docker on `9100`.\n\nThis dashboard shows only the metrics exposed by the Docker-side official exporter.",
        "mode": "markdown"
      },
      "title": "Overview",
      "type": "text"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 60},
              {"color": "red", "value": 85}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 3},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"official-node-exporter\",mode=\"idle\"}[5m])) * 100)",
          "refId": "A"
        }
      ],
      "title": "CPU Used",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "bytes"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 3},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {"expr": "node_memory_MemTotal_bytes{job=\"official-node-exporter\"}", "refId": "A"}
      ],
      "title": "Total Memory",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "bytes"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 3},
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {"expr": "node_memory_MemTotal_bytes{job=\"official-node-exporter\"} - node_memory_MemAvailable_bytes{job=\"official-node-exporter\"}", "refId": "A"}
      ],
      "title": "Current Memory Used",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 3},
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {"expr": "up{job=\"official-node-exporter\"}", "refId": "A"}
      ],
      "title": "Exporter Status",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "bytes"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 11},
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(node_filesystem_size_bytes{job=\"official-node-exporter\",fstype!~\"tmpfs|overlay\",mountpoint=\"/\"})",
          "refId": "A"
        }
      ],
      "title": "Root Disk Total",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "bytes"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 11},
      "id": 7,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(node_filesystem_size_bytes{job=\"official-node-exporter\",fstype!~\"tmpfs|overlay\",mountpoint=\"/\"} - node_filesystem_avail_bytes{job=\"official-node-exporter\",fstype!~\"tmpfs|overlay\",mountpoint=\"/\"})",
          "refId": "A"
        }
      ],
      "title": "Root Disk Used",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 11},
      "id": 8,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name"
      },
      "targets": [
        {"expr": "count(count by (cpu) (node_cpu_seconds_total{job=\"official-node-exporter\"}))", "refId": "A"}
      ],
      "title": "CPU Cores",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "Bps"},
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 19},
      "id": 9,
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total{job=\"official-node-exporter\",device!=\"lo\"}[5m]))",
          "legendFormat": "receive",
          "refId": "A"
        },
        {
          "expr": "sum(rate(node_network_transmit_bytes_total{job=\"official-node-exporter\",device!=\"lo\"}[5m]))",
          "legendFormat": "transmit",
          "refId": "B"
        }
      ],
      "title": "Network Throughput",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {"unit": "percent"},
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 19},
      "id": 10,
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"official-node-exporter\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "cpu",
          "refId": "A"
        },
        {
          "expr": "((node_memory_MemTotal_bytes{job=\"official-node-exporter\"} - node_memory_MemAvailable_bytes{job=\"official-node-exporter\"}) / node_memory_MemTotal_bytes{job=\"official-node-exporter\"}) * 100",
          "legendFormat": "memory",
          "refId": "B"
        }
      ],
      "title": "CPU vs Memory Used",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["node", "docker"],
  "templating": {"list": []},
  "time": {"from": "now-30m", "to": "now"},
