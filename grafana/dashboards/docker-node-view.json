      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "((node_memory_MemTotal_bytes{job=\"official-node-exporter\"} - node_memory_MemAvailable_bytes{job=\"official-node-exporter\"}) / node_memory_MemTotal_bytes{job=\"official-node-exporter\"}) * 100",
          "legendFormat": "Memory Used %",
          "refId": "A"
        }
      ],
      "title": "Memory Used %",
      "type": "gauge"
