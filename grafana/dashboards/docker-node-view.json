      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "content": "## Node In Docker View\n\nSource: official `node_exporter` running inside Docker on port `9100`.\n\nThis page only shows metrics exposed by the Docker-side official exporter. On macOS, these values usually describe the Docker/LinuxKit environment rather than the native host.",
        "mode": "markdown"
      },
      "title": "Overview",
      "type": "text"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 6 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        { "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"official-node-exporter\",mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU Used %", "refId": "A" }
      ],
      "title": "CPU Used %",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "max": 1, "min": 0, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 6 },
      "id": 3,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        { "expr": "up{job=\"official-node-exporter\"}", "legendFormat": "Exporter Up", "refId": "A" }
      ],
      "title": "Exporter Up",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "max": 128, "min": 0, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 },
      "id": 4,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        { "expr": "count(count by (cpu) (node_cpu_seconds_total{job=\"official-node-exporter\",mode=\"idle\"}))", "legendFormat": "CPU Cores", "refId": "A" }
      ],
      "title": "CPU Cores",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "max": 100, "min": 0, "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 6 },
