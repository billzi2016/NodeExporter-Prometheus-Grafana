      },
      "title": "Overview",
      "type": "text"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 60},
              {"color": "red", "value": 85}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 3},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {"expr": "custom_host_cpu_used_percent{job=\"custom-fastapi-exporter\"}", "refId": "A"}
      ],
      "title": "CPU Used",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
